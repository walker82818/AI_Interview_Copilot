# App
APP_NAME=AI Interview Copilot
DEBUG=true
API_PREFIX=/api
CORS_ORIGINS=http://localhost:3000

# Security
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_interview

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=ai_interview_docs

# LLM (阿里百炼 / OpenAI 兼容)
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
LLM_MODEL=qwen-plus

# Embedding / Rerank (local or API)
EMBEDDING_MODEL=BAAI/bge-m3
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# File storage
UPLOAD_DIR=uploads
